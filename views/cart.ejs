<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vircosa | Luxury Fragrances</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts (Playfair Display + Montserrat) -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="../stylesheets/navbar-styles.css">
    <link rel="stylesheet" href="../stylesheets/footer-styles.css">
    <link rel="stylesheet" href="../stylesheets/main-styles.css">
    <link rel="stylesheet" href="../stylesheets/cta-section-styles.css">

    <style>
        /* ===== Hero Section ===== */
        .hero-section {
            background: linear-gradient(rgba(42, 33, 24, 0.4), rgba(42, 33, 24, 0.4)),
                url('https://images.unsplash.com/photo-1592945403244-b3fbafd7f539?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80') no-repeat center center;
            background-size: cover;
            color: white;
            padding: 180px 0 150px;
            text-align: center;
            position: relative;
        }

        .hero-title {
            font-size: 4rem;
            margin-bottom: 20px;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.3);
        }

        .hero-subtitle {
            font-size: 1.5rem;
            margin-bottom: 30px;
            opacity: 0.9;
            font-weight: 300;
        }

        .btn-hero {
            background-color: var(--primary-color);
            color: white;
            padding: 12px 35px;
            border-radius: 30px;
            font-weight: 600;
            letter-spacing: 1px;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-hero:hover {
            background-color: var(--secondary-color);
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        }

        /* ===== Page Header ===== */
        .page-header {
            background: linear-gradient(rgba(42, 33, 24, 0.4), rgba(42, 33, 24, 0.4)),
                url('https://images.unsplash.com/photo-1592945403244-b3fbafd7f539?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80') no-repeat center center;
            background-size: cover;
            color: white;
            padding: 150px 0 100px;
            text-align: center;
            position: relative;
            margin-top: 80px;
        }

        .page-title {
            font-size: 3.5rem;
            margin-bottom: 20px;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.3);
        }

        /* ===== Cart Section ===== */
        .cart-section {
            padding: 80px 0;
        }

        .cart-container {
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .cart-header {
            background-color: var(--light-color);
            padding: 20px 30px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .cart-item {
            display: flex;
            align-items: center;
            padding: 25px 30px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .cart-item:hover {
            background-color: rgba(139, 90, 43, 0.03);
        }

        .cart-item-img {
            width: 120px;
            height: 120px;
            border-radius: 8px;
            overflow: hidden;
            margin-right: 25px;
            flex-shrink: 0;
        }

        .cart-item-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cart-item-details {
            flex-grow: 1;
        }

        .cart-item-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            color: var(--secondary-color);
            margin-bottom: 5px;
        }

        .cart-item-desc {
            color: #777;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }

        .cart-item-price {
            font-weight: 600;
            color: var(--primary-color);
            font-size: 1.1rem;
        }

        .quantity-control {
            display: flex;
            align-items: center;
            margin: 15px 0;
        }

        .qty-btn {
            width: 32px;
            height: 32px;
            background: transparent;
            border: 1px solid var(--primary-color);
            color: var(--primary-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .qty-btn:hover {
            background-color: var(--primary-color);
            color: white;
        }

        .qty-input {
            width: 50px;
            text-align: center;
            border: none;
            font-weight: 600;
            margin: 0 10px;
            font-size: 1.1rem;
            background: transparent;
        }

        .remove-item {
            color: #999;
            font-size: 0.9rem;
            cursor: pointer;
            transition: color 0.2s ease;
        }

        .remove-item:hover {
            color: var(--primary-color);
        }

        .cart-summary {
            padding: 30px;
            background-color: var(--light-color);
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .summary-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            color: var(--secondary-color);
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .total-row {
            font-weight: 600;
            font-size: 1.2rem;
            color: var(--primary-color);
            border-bottom: none;
            margin-top: 10px;
        }

        .promo-input {
            border: 1px solid #ddd;
            padding: 10px 15px;
            border-radius: 30px;
            width: 100%;
            margin-bottom: 15px;
        }

        .btn-checkout {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 30px;
            font-weight: 600;
            width: 100%;
            transition: all 0.3s ease;
        }

        .btn-checkout:hover {
            background-color: var(--secondary-color);
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

        .btn-continue {
            background-color: transparent;
            border: 1px solid var(--primary-color);
            color: var(--primary-color);
            padding: 12px 25px;
            border-radius: 30px;
            font-weight: 600;
            width: 100%;
            transition: all 0.3s ease;
        }

        .btn-continue:hover {
            background-color: var(--primary-color);
            color: white;
        }

        .empty-cart {
            text-align: center;
            padding: 80px 0;
        }

        .empty-cart i {
            font-size: 5rem;
            color: var(--accent-color);
            margin-bottom: 20px;
        }

        .empty-cart h3 {
            color: var(--secondary-color);
            margin-bottom: 20px;
        }

        /* ===== Footer ===== */
        .footer {
            background-color: var(--secondary-color);
            color: white;
            padding: 80px 0 30px;
        }

        .footer-title {
            font-size: 1.8rem;
            margin-bottom: 25px;
        }

        .footer-title span {
            color: var(--accent-color);
        }

        .footer p {
            opacity: 0.8;
            margin-bottom: 20px;
        }

        .footer-links h4 {
            font-size: 1.2rem;
            margin-bottom: 20px;
            position: relative;
            padding-bottom: 10px;
        }

        .footer-links h4:after {
            content: '';
            position: absolute;
            width: 40px;
            height: 2px;
            background-color: var(--accent-color);
            bottom: 0;
            left: 0;
        }

        .footer-links ul {
            list-style: none;
            padding-left: 0;
        }

        .footer-links li {
            margin-bottom: 10px;
        }

        .footer-links a {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .footer-links a:hover {
            color: var(--accent-color);
            padding-left: 5px;
        }

        .social-icons a {
            display: inline-block;
            width: 40px;
            height: 40px;
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
            border-radius: 50%;
            text-align: center;
            line-height: 40px;
            margin-right: 10px;
            transition: all 0.3s ease;
        }

        .social-icons a:hover {
            background-color: var(--accent-color);
            transform: translateY(-3px);
        }

        .copyright {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 20px;
            margin-top: 40px;
            text-align: center;
            font-size: 0.9rem;
            opacity: 0.7;
        }

        /* ===== Responsive Adjustments ===== */
        @media (max-width: 992px) {
            .page-title {
                font-size: 2.8rem;
            }
        }

        @media (max-width: 768px) {
            .navbar-brand {
                font-size: 1.5rem;
            }

            .cart-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .cart-item-img {
                margin-right: 0;
                margin-bottom: 20px;
            }

            .cart-item-details {
                width: 100%;
            }
        }

        @media (max-width: 576px) {
            .page-title {
                font-size: 2.2rem;
            }

            .page-header {
                padding: 120px 0 70px;
            }
        }
    </style>
</head>

<body>
    <%- include('partials/navbar') %>

    <!-- Added to cart notification (for all pages) -->
    <div class="position-fixed bottom-0 end-0 p-3 toast-container" style="z-index: 11"></div>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <h1 class="hero-title">Elegance in Every Drop</h1>
            <p class="hero-subtitle">Discover the art of fragrance with Zephyra Luxe</p>
            <a href="#products" class="btn btn-hero">Explore Scents</a>
        </div>
    </section>


    <!-- Cart Section -->
    <section class="cart-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <div class="cart-container">
                        <div class="cart-header">
                            <h3 class="mb-0">Your Cart <span class="text-muted"><%= total_items %> items</span></h3>
                        </div>

                        <!-- Cart Items -->
                        <% if (cartItems.length > 0) { %>
                            <% cartItems.forEach(item => { %>
                                <div class="cart-item" data-product-id="<%= item.product._id %>">
                                    <div class="cart-item-img">
                                        <img src="<%= item.product.images[0] %>" alt="<%= item.product.name %>">
                                    </div>
                                    <div class="cart-item-details">
                                        <h4 class="cart-item-title"><%= item.product.name %></h4>
                                        <p class="cart-item-desc">PKR <%= item.product.price %></p>
                                    </div>
                                    
                                    <div class="quantity-control me-4">
                                        <button class="qty-btn minus" data-id="<%= item.product._id %>" data-price="<%= item.product.price %>">
                                            <i class="fas fa-minus"></i>
                                        </button>
                                        <input type="text" class="qty-input" data-id="<%= item.product._id %>" value="<%= item.quantity %>" readonly>
                                        <button class="qty-btn plus" data-id="<%= item.product._id %>" data-price="<%= item.product.price %>">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                    
                                    <div class="cart-item-total">
                                        <span class="cart-item-price item-total-price" data-id="<%= item.product._id %>">
                                            PKR <%= (item.product.price * item.quantity).toFixed(2) %>
                                        </span>
                                    </div>

                                    <div class="ms-auto">
                                        <span class="remove-item" data-id="<%= item.product._id %>">Remove</span>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        </div>

                        <div class="col-lg-4 mt-4 mt-lg-0">
                            <div class="cart-summary">
                                <h3 class="summary-title">Order Summary</h3>
        
                                <div class="summary-row">
                                    <span>Subtotal</span>
                                    <span>PKR <%= subtotal %></span>
                                </div>
        
                                <div class="summary-row">
                                    <span>Shipping</span>
                                    <span>PKR <%= shipping %></span>
                                </div>
        
                                <div class="summary-row">
                                    <span>Tax</span>
                                    <span>PKR <%= tax.toFixed(2) %></span>
                                </div>
        
                                <div class="summary-row total-row">
                                    <span>Total</span>
                                    <span>PKR <%= total.toFixed(2) %></span>
                                </div>
        
                            <% } else { %>
                                <p>Your cart is empty.</p>
                                <% } %>
        
                            <!-- <div class="mt-4">
                                <input type="text" class="form-control promo-input" placeholder="Promo Code">
                                <button class="btn btn-outline-perfume w-100 mb-3">Apply Code</button>
                            </div> -->
        
                            <button onclick="location.href='/checkout'" class="btn btn-checkout mb-3">Proceed to
                                Checkout</button>
                            <button onclick="location.href='/products'" class="btn btn-continue">Continue
                                Shopping</button>
        
                        </div>
        
                        <!-- <div class="mt-4 text-center">
                                    <p><i class="fas fa-lock me-2"></i> Secure Checkout</p>
                                    <div class="d-flex justify-content-center mt-2">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b7/MasterCard_Logo.svg"
                                        alt="Mastercard" height="30" class="me-2">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/5/5e/Visa_Inc._logo.svg" alt="Visa"
                                        height="30" class="me-2">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/f/fa/American_Express_logo_%282018%29.svg"
                                        alt="Amex" height="30" class="me-2">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" alt="PayPal"
                                        height="30">
                                    </div>
                                </div> -->
                    </div>
                </div>
    </section>

    <%- include('partials/newsletter') %>
                <%- include('partials/footer') %>

    <!-- Bootstrap JS (for navbar toggle) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Cart Functionality -->
    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', function () {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // Remove item
        document.querySelectorAll('.remove-item').forEach(button => {
            button.addEventListener('click', function () {
                const id = this.getAttribute('data-id');
                const item = document.querySelector(`.cart-item .remove-item[data-id="${id}"]`).closest('.cart-item');

                // Add animation
                item.style.opacity = '0';
                item.style.transform = 'translateX(-20px)';

                setTimeout(() => {
                    item.remove();
                    updateCartTotals();
                    updateCartCount();
                }, 300);
            });
        });

        // Update cart count in navbar
        // function updateCartCount() {
        //     const count = document.querySelectorAll('.cart-item').length;
        //     document.querySelector('.badge').textContent = count;
        // }

        // Cart Functionality
document.addEventListener('DOMContentLoaded', () => {
    
    // Function to handle the actual AJAX/Fetch request
    async function updateCartItemQuantity(productId, action) {
        try {
            const response = await fetch('/cart/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ productId, action })
            });

            if (!response.ok) {
                throw new Error('Failed to update cart');
            }

            const data = await response.json();

            // 1. Update the total item count badge (if you have one)
            document.querySelector('.cart-header h3 .text-muted').textContent = `${data.total_items} items`;

            // 2. Recalculate ALL totals on the client side for speed
            updateLocalCartTotals();

            // Check if the item was removed (quantity reached 0)
            if (action === 'decrease' && data.newQuantity === undefined) {
                 const itemElement = document.querySelector(`.cart-item[data-product-id="${productId}"]`);
                 itemElement.remove();
            }

        } catch (error) {
            console.error('Error updating cart:', error);
            // Optionally show a user error message
        }
    }

    // Function to update all local totals (subtotal, tax, total)
    function updateLocalCartTotals() {
        let newSubtotal = 0;
        let newTotalItems = 0;
        const shipping = 300; // Hardcoded from your route

        document.querySelectorAll('.cart-item').forEach(itemElement => {
            const productId = itemElement.getAttribute('data-product-id');
            const qtyInput = itemElement.querySelector(`.qty-input[data-id="${productId}"]`);
            const price = parseFloat(itemElement.querySelector('.qty-btn').getAttribute('data-price'));
            const quantity = parseInt(qtyInput.value);

            const itemTotal = price * quantity;
            newSubtotal += itemTotal;
            newTotalItems += quantity;

            // Update the individual item's total price display
            itemElement.querySelector('.item-total-price').textContent = `PKR ${itemTotal.toFixed(2)}`;
        });
        
        const newTax = newSubtotal * 0.17;
        const newTotal = newSubtotal + shipping + newTax;

        // Update the display in the Order Summary section
        document.querySelector('.cart-header h3 .text-muted').textContent = `${newTotalItems} items`;
        document.querySelector('.summary-row span:nth-child(2)').textContent = `PKR ${newSubtotal.toFixed(2)}`;
        document.querySelector('.summary-row:nth-child(3) span:nth-child(2)').textContent = `PKR ${shipping}`;
        document.querySelector('.summary-row:nth-child(4) span:nth-child(2)').textContent = `PKR ${newTax.toFixed(2)}`;
        document.querySelector('.total-row span:nth-child(2)').textContent = `PKR ${newTotal.toFixed(2)}`;
    }


        // Attach click handlers to the quantity buttons
        document.querySelectorAll('.qty-btn').forEach(button => {
            button.addEventListener('click', function () {
                const productId = this.getAttribute('data-id');
                const input = document.querySelector(`.qty-input[data-id="${productId}"]`);
                let value = parseInt(input.value);
                let action = '';

                if (this.classList.contains('minus')) {
                    if (value > 1) {
                        input.value = value - 1;
                        action = 'decrease';
                    } else if (value === 1) {
                        // This handles the case where the item will be removed
                        input.value = 0; // Temporarily show 0
                        action = 'decrease';
                    } else {
                        return; // Do nothing if value is already 0
                    }
                } else if (this.classList.contains('plus')) {
                    input.value = value + 1;
                    action = 'increase';
                }

                if (action) {
                    // Optimistically update the UI before the fetch (optional)
                    updateLocalCartTotals(); 
                    updateCartItemQuantity(productId, action);
                }
            });
        });
        
        // Initial calculation when the page loads
        updateLocalCartTotals();

        // The rest of the cart functionality (remove item, navbar scroll, etc.) goes here
    });


    </script>
</body>

</html>