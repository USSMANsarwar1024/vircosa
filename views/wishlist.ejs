<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vircosa | Luxury Fragrances</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts (Playfair Display + Montserrat) -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="../stylesheets/navbar-styles.css">
    <link rel="stylesheet" href="../stylesheets/footer-styles.css">
    <link rel="stylesheet" href="../stylesheets/main-styles.css">
    <link rel="stylesheet" href="../stylesheets/cta-section-styles.css">

    <!-- Custom CSS -->
    <style>
        /* ===== Wishlist Header ===== */
        .wishlist-header {
            background: linear-gradient(rgba(42, 33, 24, 0.7), rgba(42, 33, 24, 0.7)) ;
                background-image: url("D:\Zephyr Website\WhatsApp Image 2025-05-26 at 8.55.08 PM.jpeg") no-repeat center center;

            background-size: cover;
            color: white;
            padding: 120px 0 80px;
            text-align: center;
            margin-bottom: 60px;
        }

        .wishlist-title {
            font-size: 3.5rem;
            margin-bottom: 15px;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.3);
        }

        .wishlist-subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            font-weight: 300;
            max-width: 600px;
            margin: 0 auto;
        }

        /* ===== Wishlist Section ===== */
        .wishlist-section {
            padding: 60px 0 100px;
        }

        .section-title {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-title h2 {
            font-weight: 700;
            color: var(--secondary-color);
            position: relative;
            display: inline-block;
            padding-bottom: 15px;
        }

        .section-title h2:after {
            content: '';
            position: absolute;
            width: 80px;
            height: 2px;
            background-color: var(--primary-color);
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
        }

        .wishlist-empty {
            text-align: center;
            padding: 80px 0;
        }

        .wishlist-empty i {
            font-size: 4rem;
            color: var(--accent-color);
            margin-bottom: 20px;
        }

        .wishlist-empty h3 {
            margin-bottom: 20px;
            color: var(--secondary-color);
        }

        .wishlist-empty p {
            color: #666;
            margin-bottom: 30px;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }

        .btn-wishlist {
            background-color: var(--primary-color);
            color: white;
            padding: 12px 35px;
            border-radius: 30px;
            font-weight: 600;
            letter-spacing: 1px;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-wishlist:hover {
            background-color: var(--secondary-color);
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            color: white;
        }

        /* Wishlist Items */
        .wishlist-item {
            background-color: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
            transition: all 0.4s ease;
            margin-bottom: 30px;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .wishlist-item-img {
            height: 300px;
            overflow: hidden;
        }

        .wishlist-item-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .wishlist-item:hover .wishlist-item-img img {
            transform: scale(1.05);
            
        }

        .wishlist-item-body {
            padding: 25px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .wishlist-item-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            margin-bottom: 10px;
            color: var(--secondary-color);
        }

        .wishlist-item-desc {
            color: #666;
            margin-bottom: 20px;
            font-size: 0.95rem;
            flex-grow: 1;
        }

        .wishlist-item-price {
            font-weight: 600;
            color: var(--primary-color);
            font-size: 1.2rem;
            margin-bottom: 20px;
        }

        .wishlist-item-actions {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            
        }

        .btn-wishlist-action {
            flex: 1;
            text-align: center;
            padding: 10px;
            border-radius: 5px;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .btn-move-to-cart {
            background-color: var(--primary-color);
            color: white;
            border: 1px solid var(--primary-color);
        }

        .btn-move-to-cart:hover {
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
            color: white;
        }

        .btn-remove {
            background-color: transparent;
            color: #dc3545;
            border: 1px solid #dc3545;
        }

        .btn-remove:hover {
            background-color: #BB9351;
            color: white;
        }

        /* ===== Responsive Adjustments ===== */
        @media (max-width: 992px) {
            .wishlist-title {
                font-size: 3rem;
            }
        }

        @media (max-width: 768px) {
            .navbar-brand {
                font-size: 1.5rem;
            }

            .wishlist-header {
                padding: 100px 0 60px;
            }

            .wishlist-item-title {
                font-size: 1.3rem;
            }
        }

        @media (max-width: 576px) {
            .wishlist-title {
                font-size: 2.2rem;
            }

            .section-title h2 {
                font-size: 1.8rem;
            }

            .wishlist-item-actions {
                flex-direction: column;
            }

            .btn-wishlist-action {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <%- include('partials/navbar') %>


    <!-- Wishlist Header -->
    <section class="wishlist-header">
        <div class="container">
            <h1 class="wishlist-title">My Fragrance Wishlist</h1>
            <p class="wishlist-subtitle">Your curated collection of scents waiting to be discovered</p>
        </div>
    </section>

    <!-- Wishlist Section -->
    <section class="wishlist-section">
        <div class="container">
            <div class="section-title">
                <h2>Saved For Later</h2>
                <p class="text-muted">Your most desired fragrances</p>
            </div>

            <!-- Wishlist Items Grid -->
            <div class="row" id="wishlist-items">
                <!-- Wishlist items will be dynamically inserted here -->
                
                <% if (wishlistItems.length > 0) { %>
                    <% wishlistItems.forEach(item => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="wishlist-item" data-product-id="<%= item._id %>">
                                <div class="wishlist-item-img">
                                    <img src="<%= item.images[0] %>" alt="<%= item.name %>">
                                </div>
                                <div class="wishlist-item-body">
                                    <h3 class="wishlist-item-title"> <%= item.name %> </h3>
                                    <p class="wishlist-item-desc"> <%= item.description %> </p>
                                    <p class="wishlist-item-price"> PKR <%= item.price %> </p>
                                    <div class="wishlist-item-actions">
                                        <button class="btn btn-wishlist-action btn-move-to-cart">Add to Cart</button>
                                        <button class="btn btn-wishlist-action btn-remove">Remove</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    
                    <% }) %>
                <% } else { %>
                    <!-- Empty Wishlist State (hidden by default) -->
                    <div class="wishlist-empty" id="empty-wishlist">
                        <i class="far fa-heart"></i>
                        <h3>Your Wishlist is Empty</h3>
                        <p>Start exploring our collection of luxury fragrances and add your favorites to your wishlist.</p>
                        <a href="/product" class="btn btn-wishlist">Discover Scents</a>
                    </div>
                <% } %>
                
                
                

            <!-- Wishlist Actions -->
            <div class="text-center mt-5" id="wishlist-actions">
                <button class="btn btn-outline-perfume me-2" id="clear-wishlist">Clear Wishlist</button>
                <a href="/products" class="btn btn-wishlist">Continue Shopping</a>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>
    


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Font Awesome JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
</body>

</html>